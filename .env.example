# ShipNuts Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.

# === Claude Code / Anthropic API ===
# Required: Your Anthropic API key (or third-party provider key)
ANTHROPIC_API_KEY=

# Optional: Custom API base URL for third-party providers
# Uncomment and set if you use OpenRouter, a proxy, or a custom endpoint.
# ANTHROPIC_BASE_URL=https://your-provider.com/v1

# === Server ===
# Optional: Server port (default: 3456)
# PORT=3456
